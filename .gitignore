.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example

# Service keys - never commit. Trial keys live in this folder during dev;
# real keys come from a user-provided service instance via VCAP_SERVICES.
sk*.json
*service-key*.json
*-cis.json
*-ident.json
*-ias.json
*-xsuaa*.json
service-keys/
keys/

# Local secrets / docker
docker-compose.override.yml

# Generated by `./gradlew prepareApprouter` (also run as part of bootJar).
# The canonical UI source is src/main/resources/static/; this is just a
# copy for the approuter's localDir handler at deploy time.
approuter/resources/
