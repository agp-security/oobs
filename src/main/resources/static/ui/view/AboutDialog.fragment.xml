<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <Dialog title="{i18n>dlgAboutTitle}" contentWidth="34rem">
        <content>
            <l:VerticalLayout width="100%" class="sapUiContentPadding">
                <HBox alignItems="Center">
                    <Image src="/favicon.svg" width="3rem" height="3rem"/>
                    <l:VerticalLayout class="sapUiSmallMarginBegin">
                        <Title text="{i18n>appTitle}" level="H2"/>
                        <Text text="{i18n>appShellSubtitle}"/>
                    </l:VerticalLayout>
                </HBox>

                <Text text="{i18n>aboutDescription}" class="sapUiSmallMarginTop"/>

                <Title text="{i18n>aboutScopesTitle}" level="H3" class="sapUiSmallMarginTop"/>
                <List inset="false">
                    <StandardListItem title="{i18n>aboutScopeAdmin}" icon="sap-icon://shield"/>
                    <StandardListItem title="{i18n>aboutScopeResponder}" icon="sap-icon://locked"/>
                    <StandardListItem title="{i18n>aboutScopeViewer}" icon="sap-icon://show"/>
                </List>

                <HBox class="sapUiSmallMarginTop">
                    <Label text="{i18n>aboutVersion}: " class="sapUiTinyMarginEnd"/>
                    <Text text="{shell>/version}"/>
                </HBox>

                <HBox alignItems="Center">
                    <Label text="{i18n>aboutSource}: " class="sapUiTinyMarginEnd"/>
                    <Link text="{i18n>aboutGithub}"
                          href="https://github.com/agp-security/oobs"
                          target="_blank"/>
                </HBox>
            </l:VerticalLayout>
        </content>
        <buttons>
            <Button text="{i18n>aboutClose}" press=".onCloseAbout"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>
